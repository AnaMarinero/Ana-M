#include <stdio.h>
#include <stdlib.h>

/* run this program using the console pauser or add your own getch, system("pause") or input loop */
/* Los limites inferioes para calcular la renta*/
const float reLI1 = 0.01;
const float	reLI2 = 472.01;
const float	reLI3 = 895.25;
const float	reLI4 = 2038.11;
/* Los limites superiores para calcular la renta.*/
const float	reLS1 = 472.00;
const float	reLS2 = 895.24;
const float	reLS3 = 2038.10;
/* los valores de renta fija*/
const float reCF1 = 17.67;
const float reCF2 = 60.00;
const float reCF3 = 288.57;
int main(int argc, char *argv[]) {
	float SN, AFP, ISSS, IG, R, R2, R3, R4, T, G, SNM, SNQ;
	/*SN = salario nominal, en base a este se calculara el AFP y el ISSS
	AFP es el 7.23 porciento del nominal
	ISSS es el 3 porciento del nominal*/
	/*IG es el ingreso gravado que es igual al SN-(AFP+ISSS)
	SNM= es el salario neto mensual y es igual al IG-la renta R
	el valor de la renta variara 
	SNQ= es igual al salario quiencenal que es igual al SNM entre 2*/
	printf("ingrese su salario nominal: ");
	scanf("%f", &SN);
	AFP=(SN*0.0725);
	ISSS=(SN*0.03);
	IG=(SN-AFP-ISSS);
	
	printf("\n Salario nominal: %f \n AFP %f \n ISSS: %f \n IG: %f", SN, AFP, ISSS, IG);
	/*calculo de la renta:
	Para este */
	if(IG>= reLI1 && reLS1>=IG)
		{R=0; printf("\n No se aplica renta", R);}
		else if
			(IG>= reLI2 && reLS2>=IG)
			{T=IG-reLI2; G=T*0.1;
			R2=(G + reCF1); printf("\n Renta: %f",R2);}
				else if
					(IG>= reLI3 && reLS3>=IG)	
					{T=IG-reLI3; G=T*0.2;
					R3=(G + reCF2);printf("\n Renta: %f",R3);}
						else{
						
							T=IG-reLI4; G=T*0.3;
						R4=(G + reCF3);printf("\n Renta: %f",R4);}
					
		
	
	
return 0;}
